# ============================================================
# Control-Church Backend — Variables de entorno
# Copiar a .env y completar los valores reales
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development

# Base de datos SQL Server (Azure Serverless)
DB_HOST=tu-servidor.database.windows.net
DB_PORT=1433
DB_DATABASE=control-church
DB_USERNAME=tu_usuario
DB_PASSWORD=tu_password
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_caracteres
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=https://control-church.tulogro.dev/api/auth/google/callback

# Azure Blob Storage (fotos de miembros, logos, comprobantes)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=control-church

# CORS — frontend URL
CORS_ORIGIN=https://control-church.tulogro.dev
